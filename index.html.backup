<!DOCTYPE html>
<html lang="zh-CN" class="dark scroll-smooth">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>个人作品集 · 字节跳动求职</title>
<script src="https://cdn.tailwindcss.com"></script>
<script>tailwind.config={darkMode:'class',theme:{extend:{colors:{brand:{50:'#f0f1f3',100:'#d9dce1',200:'#b3b9c3',300:'#8d96a5',400:'#677387',500:'#4a5568',600:'#3a4252',700:'#2d3340',800:'#1e222b',900:'#14171d',950:'#0b0d11'},accent:{DEFAULT:'#3b82f6',light:'#60a5fa',dark:'#2563eb'}}}}}</script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
body{font-family:'Inter','PingFang SC','Microsoft YaHei',system-ui,sans-serif}
::selection{background:rgba(59,130,246,.3);color:#fff}
::-webkit-scrollbar{width:6px}.dark ::-webkit-scrollbar-track{background:#14171d}::-webkit-scrollbar-thumb{background:#3a4252;border-radius:3px}
.sf{transition:width 1.2s cubic-bezier(.4,0,.2,1)}
.ch:hover{transform:translateY(-4px)}.dark .ch:hover{box-shadow:0 8px 30px rgba(0,0,0,.4);border-color:rgba(59,130,246,.3)}.ch:hover .cc{transform:scale(1.03)}.cc{transition:transform .4s}
.nl{position:relative}.nl::after{content:'';position:absolute;bottom:-2px;left:0;width:0;height:2px;background:#3b82f6;transition:width .3s}.nl:hover::after,.nl.act::after{width:100%}
.fi{opacity:0;transform:translateY(20px);transition:opacity .6s,transform .6s}.fi.vis{opacity:1;transform:translateY(0)}
.tp{transition:background-color .2s,color .2s}
.cl{max-height:0;overflow:hidden;transition:max-height .4s}.cl.open{max-height:500px}
.eh{outline:1px dashed rgba(59,130,246,.5);outline-offset:2px}[contenteditable]:focus{outline:2px solid #3b82f6;outline-offset:2px;border-radius:2px}
.lm{opacity:0;transition:opacity .5s}.lm.ld{opacity:1}
video::-webkit-media-controls{opacity:0;transition:opacity .3s}video:hover::-webkit-media-controls{opacity:1}
.do{border:2px dashed #3b82f6!important}
</style>
</head>
<body class="bg-white dark:bg-brand-950 text-brand-800 dark:text-brand-100 antialiased transition-colors duration-300">

<div id="eb" class="hidden fixed top-0 left-0 right-0 z-[60] bg-accent text-white text-center text-xs py-1.5 font-medium">编辑模式已开启 · Ctrl+Shift+E 退出 · 修改自动保存</div>

<header id="nb" class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-brand-950/80 backdrop-blur-md border-b border-gray-200 dark:border-brand-800/50 transition-all duration-300">
<nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
<a href="#hero" class="text-sm font-semibold tracking-wide hover:text-accent transition-colors" data-e="profile.name">张三</a>
<div class="hidden sm:flex items-center gap-6">
<a href="#about" class="nl text-xs font-medium text-brand-400 dark:text-brand-300 hover:text-brand-800 dark:hover:text-brand-100 transition-colors">关于我</a>
<a href="#works" class="nl text-xs font-medium text-brand-400 dark:text-brand-300 hover:text-brand-800 dark:hover:text-brand-100 transition-colors">核心作品</a>
<a href="#skills" class="nl text-xs font-medium text-brand-400 dark:text-brand-300 hover:text-brand-800 dark:hover:text-brand-100 transition-colors">技能栈</a>
<a href="#experience" class="nl text-xs font-medium text-brand-400 dark:text-brand-300 hover:text-brand-800 dark:hover:text-brand-100 transition-colors">项目经历</a>
<a href="#contact" class="nl text-xs font-medium text-brand-400 dark:text-brand-300 hover:text-brand-800 dark:hover:text-brand-100 transition-colors">联系方式</a>
</div>
<div class="flex items-center gap-2">
<button id="tt" class="w-8 h-8 rounded-lg flex items-center justify-center text-brand-400 dark:text-brand-300 hover:bg-gray-100 dark:hover:bg-brand-800 transition-colors" aria-label="切换主题">
<svg class="w-4 h-4 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/></svg>
<svg class="w-4 h-4 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
</button>
<button id="sb" class="hidden w-8 h-8 rounded-lg items-center justify-center text-brand-400 dark:text-brand-300 hover:bg-gray-100 dark:hover:bg-brand-800 transition-colors" aria-label="设置">
<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
</button>
<button id="mb" class="sm:hidden w-8 h-8 rounded-lg flex items-center justify-center text-brand-400 dark:text-brand-300 hover:bg-gray-100 dark:hover:bg-brand-800 transition-colors" aria-label="菜单">
<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
</button>
</div>
</nav>
<div id="mm" class="sm:hidden hidden bg-white/95 dark:bg-brand-950/95 backdrop-blur-md border-b border-gray-200 dark:border-brand-800/50">
<div class="px-4 py-3 flex flex-col gap-3">
<a href="#about" class="mn text-xs font-medium text-brand-400 dark:text-brand-300 py-1">关于我</a>
<a href="#works" class="mn text-xs font-medium text-brand-400 dark:text-brand-300 py-1">核心作品</a>
<a href="#skills" class="mn text-xs font-medium text-brand-400 dark:text-brand-300 py-1">技能栈</a>
<a href="#experience" class="mn text-xs font-medium text-brand-400 dark:text-brand-300 py-1">项目经历</a>
<a href="#contact" class="mn text-xs font-medium text-brand-400 dark:text-brand-300 py-1">联系方式</a>
</div></div>
</header>

<main class="pt-14">
<section id="hero" class="min-h-[85vh] flex items-center justify-center"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center fi">
<p class="text-xs font-medium tracking-widest text-accent uppercase mb-4" data-e="profile.role1">AIGC设计实习生 · 效果创意设计实习生</p>
<h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 dark:text-white tracking-tight mb-4" data-e="profile.name2">张三</h1>
<p class="text-lg sm:text-xl text-brand-500 dark:text-brand-300 font-light mb-3" data-e="profile.tagline">以 AI 为画笔，以创意为引擎</p>
<p class="text-sm text-brand-400 max-w-xl mx-auto mb-8 leading-relaxed" data-e="profile.bio">专注 AIGC 视觉创意与效果设计，擅长将 AI 生成能力与商业场景深度结合，追求技术与审美的极致融合</p>
<div class="flex flex-col sm:flex-row items-center justify-center gap-3">
<a href="#works" class="inline-flex items-center px-6 py-2.5 bg-accent hover:bg-accent-dark text-white text-sm font-medium rounded transition-colors">查看作品</a>
<a href="resume.pdf" download class="inline-flex items-center px-6 py-2.5 border border-gray-300 dark:border-brand-600 hover:border-accent text-brand-600 dark:text-brand-200 text-sm font-medium rounded transition-colors">下载简历</a>
</div></div></section>

<section id="about" class="py-20 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 fi">
<h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-10 tracking-tight">关于我</h2>
<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
<div class="md:col-span-1"><div class="bg-gray-50 dark:bg-brand-900 border border-gray-200 dark:border-brand-800/50 rounded-lg p-6 transition-colors"><div class="space-y-4 text-sm">
<div><span class="text-brand-400 text-xs font-medium">教育背景</span><p class="text-brand-700 dark:text-brand-100 mt-1" data-e="profile.school">某某大学</p><p class="text-brand-400" data-e="profile.major">视觉传达设计 · 本科</p><p class="text-brand-400">2026届</p></div>
<div class="border-t border-gray-200 dark:border-brand-800/50 pt-4"><span class="text-brand-400 text-xs font-medium">所在城市</span><p class="text-brand-700 dark:text-brand-100 mt-1" data-e="profile.city">深圳</p></div>
<div class="border-t border-gray-200 dark:border-brand-800/50 pt-4"><span class="text-brand-400 text-xs font-medium">实习经历</span><p class="text-brand-700 dark:text-brand-100 mt-1" data-e="profile.company">某互联网公司 · 设计实习生</p></div>
</div></div></div>
<div class="md:col-span-2 space-y-6">
<div><h3 class="text-sm font-medium text-brand-600 dark:text-brand-200 mb-2">背景概述</h3><p class="text-sm text-brand-400 leading-relaxed" data-e="profile.background">视觉传达设计专业出身，在校期间系统学习了平面设计、品牌设计、动态视觉等核心课程，同时自学 AIGC 工具链，将 AI 生成能力融入传统设计流程，形成了「AI 辅助创意 + 人工精修把控」的独特工作方式</p></div>
<div><h3 class="text-sm font-medium text-brand-600 dark:text-brand-200 mb-2">职业方向</h3><p class="text-sm text-brand-400 leading-relaxed" data-e="profile.direction">致力于成为 AIGC 视觉创意领域的复合型人才，聚焦 AI 图像生成、效果创意设计、Prompt 工程三大方向，期望在字节跳动效果与创作团队中将 AI 创意能力转化为可量化的商业价值</p></div>
<div><h3 class="text-sm font-medium text-brand-600 dark:text-brand-200 mb-2">核心优势</h3><p class="text-sm text-brand-400 leading-relaxed" data-e="profile.strengths">① 设计功底扎实，审美把控力强，能独立完成从概念到交付的全流程；② AIGC 工具链熟练，Midjourney/Stable Diffusion/Runway 等均有深度使用经验；③ Prompt 工程能力突出，能精准控制 AI 输出质量与风格；④ 数据驱动思维，善于通过 A/B 测试优化创意效果；⑤ 高效自驱，快速学习新技术并落地应用</p></div>
<div class="flex flex-wrap gap-2 pt-2">
<span class="tp px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 rounded-full cursor-default">自驱力</span>
<span class="tp px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 rounded-full cursor-default">快速学习能力</span>
<span class="tp px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 rounded-full cursor-default">跨团队协作意识</span>
<span class="tp px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 rounded-full cursor-default">项目全流程跟进交付</span>
<span class="tp px-3 py-1 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 rounded-full cursor-default">审美把控</span>
</div></div></div></div></section>

<section id="works" class="py-20 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 fi">
<div class="flex items-center justify-between mb-8">
<h2 class="text-2xl font-semibold text-gray-900 dark:text-white tracking-tight">核心作品</h2>
<button id="awb" class="hidden items-center gap-1.5 px-4 py-2 bg-accent hover:bg-accent-dark text-white text-xs font-medium rounded transition-colors">+ 添加作品</button>
</div>
<div id="tbar" class="flex flex-wrap gap-2 mb-4"></div>
<div id="subtbar" class="flex flex-wrap gap-2 mb-8 border-l-2 border-gray-200 dark:border-brand-700 pl-4"></div>
<div id="wgrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
</div></section>

<section id="skills" class="py-20 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 fi">
<h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-10 tracking-tight">技能栈</h2>
<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
<div><h3 class="text-sm font-medium text-brand-600 dark:text-brand-200 mb-5">设计工具</h3><div id="skd" class="space-y-4"></div></div>
<div><h3 class="text-sm font-medium text-brand-600 dark:text-brand-200 mb-5">AIGC 能力</h3><div id="ska" class="space-y-4"></div></div>
</div></div></section>

<section id="experience" class="py-20 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 fi">
<h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-10 tracking-tight">项目经历</h2>
<div id="expl" class="space-y-6"></div>
</div></section>

<section id="contact" class="py-20 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 fi">
<h2 class="text-2xl font-semibold text-gray-900 dark:text-white mb-10 tracking-tight">联系方式</h2>
<div id="cgrid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5"></div>
</div></section>
</main>

<footer class="py-8 border-t border-gray-200 dark:border-brand-800/30"><div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 text-center"><p class="text-xs text-brand-400">&copy; 2026 张三 · 深圳</p></div></footer>

<div class="fixed bottom-6 right-6 z-40">
<div id="cfp" class="mb-3 bg-white dark:bg-brand-900 border border-gray-200 dark:border-brand-800/50 rounded-lg p-4 shadow-2xl w-56 transition-all duration-300 origin-bottom-right scale-95 opacity-0 pointer-events-none">
<p class="text-xs font-medium text-brand-600 dark:text-brand-200 mb-3">快速联系</p>
<div id="cfc" class="space-y-2"></div>
</div>
<button id="cft" class="w-11 h-11 rounded-full bg-accent hover:bg-accent-dark text-white shadow-lg flex items-center justify-center transition-colors" aria-label="联系方式">
<svg id="cio" class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
<svg id="cic" class="w-5 h-5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
</button></div>

<!-- Work Modal -->
<div id="wm" class="fixed inset-0 z-[70] hidden">
<div class="absolute inset-0 bg-black/50" id="wm-overlay"></div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg max-h-[85vh] overflow-y-auto bg-white dark:bg-brand-900 rounded-lg shadow-2xl border border-gray-200 dark:border-brand-800/50">
<div class="p-6">
<div class="flex items-center justify-between mb-6"><h3 id="wmt" class="text-lg font-semibold text-gray-900 dark:text-white">添加作品</h3><button id="wmc" class="w-8 h-8 rounded-lg flex items-center justify-center text-brand-400 hover:bg-gray-100 dark:hover:bg-brand-800"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>
<form id="wform" class="space-y-4">
<input type="hidden" id="wf-id"/>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">作品标题</label><input type="text" id="wf-title" required class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">描述</label><textarea id="wf-desc" rows="3" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100 resize-none"></textarea></div>
<div class="grid grid-cols-2 gap-4">
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">类型</label><select id="wf-type" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"><option value="image">图片</option><option value="video">视频</option><option value="link">外链</option></select></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">分组</label><select id="wf-group" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"></select></div>
</div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">媒体文件</label><input type="file" id="wf-file" accept="image/*,video/*" class="w-full text-sm text-brand-400 file:mr-3 file:py-1.5 file:px-3 file:rounded file:border-0 file:text-xs file:font-medium file:bg-accent file:text-white hover:file:bg-accent-dark"/><p class="text-[10px] text-brand-400 mt-1">选择文件后自动上传至 GitHub；也可直接填写 URL</p></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">媒体 URL</label><input type="text" id="wf-media" placeholder="https://..." class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">封面 URL（可选）</label><input type="text" id="wf-cover" placeholder="https://..." class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">外链地址</label><input type="text" id="wf-link" placeholder="https://..." class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">标签（逗号分隔）</label><input type="text" id="wf-tags" placeholder="AI图像创作,Prompt工程" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">工作流</label><textarea id="wf-wf" rows="2" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100 resize-none"></textarea></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">创作思路</label><textarea id="wf-ct" rows="2" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100 resize-none"></textarea></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">业务适配思考</label><textarea id="wf-ba" rows="2" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100 resize-none"></textarea></div>
<div id="ups" class="hidden text-xs text-brand-400"></div>
<div class="flex gap-3 pt-2">
<button type="submit" class="flex-1 px-4 py-2 bg-accent hover:bg-accent-dark text-white text-sm font-medium rounded transition-colors">保存</button>
<button type="button" id="wf-cancel" class="px-4 py-2 border border-gray-300 dark:border-brand-600 text-brand-600 dark:text-brand-200 text-sm font-medium rounded hover:bg-gray-50 dark:hover:bg-brand-800 transition-colors">取消</button>
</div></form></div></div></div>

<!-- Settings Modal -->
<div id="stm" class="fixed inset-0 z-[70] hidden">
<div class="absolute inset-0 bg-black/50" id="stm-overlay"></div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-md bg-white dark:bg-brand-900 rounded-lg shadow-2xl border border-gray-200 dark:border-brand-800/50">
<div class="p-6">
<div class="flex items-center justify-between mb-6"><h3 class="text-lg font-semibold text-gray-900 dark:text-white">GitHub 媒体上传配置</h3><button id="stmc" class="w-8 h-8 rounded-lg flex items-center justify-center text-brand-400 hover:bg-gray-100 dark:hover:bg-brand-800"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg></button></div>
<form id="sform" class="space-y-4">
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">GitHub Token</label><input type="password" id="sf-token" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100" placeholder="ghp_xxxxxxxxxxxx"/><p class="text-[10px] text-brand-400 mt-1">需 repo 权限，加密存储于 localStorage</p></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">用户名</label><input type="text" id="sf-user" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100" placeholder="your-username"/></div>
<div><label class="block text-xs font-medium text-brand-500 dark:text-brand-300 mb-1">仓库名</label><input type="text" id="sf-repo" class="w-full px-3 py-2 text-sm bg-gray-50 dark:bg-brand-800 border border-gray-200 dark:border-brand-700 rounded focus:outline-none focus:border-accent text-gray-900 dark:text-brand-100" placeholder="portfolio-media"/></div>
<div class="bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800/50 rounded p-3"><p class="text-[11px] text-yellow-700 dark:text-yellow-300 leading-relaxed"><strong>安全提示：</strong>Token 仅加密存储于浏览器 localStorage，不会发送至第三方。纯前端加密非绝对安全，请勿在公共设备保存。建议使用 Fine-grained Token 并设置过期时间。</p></div>
<div class="flex gap-3 pt-2">
<button type="submit" class="flex-1 px-4 py-2 bg-accent hover:bg-accent-dark text-white text-sm font-medium rounded transition-colors">保存配置</button>
<button type="button" id="sf-cancel" class="px-4 py-2 border border-gray-300 dark:border-brand-600 text-brand-600 dark:text-brand-200 text-sm font-medium rounded hover:bg-gray-50 dark:hover:bg-brand-800 transition-colors">取消</button>
</div></form></div></div></div>

<!-- Confirm Dialog -->
<div id="cdlg" class="fixed inset-0 z-[80] hidden">
<div class="absolute inset-0 bg-black/50" id="cd-overlay"></div>
<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-sm bg-white dark:bg-brand-900 rounded-lg shadow-2xl border border-gray-200 dark:border-brand-800/50 p-6">
<p id="cd-msg" class="text-sm text-gray-900 dark:text-brand-100 mb-6"></p>
<div class="flex gap-3">
<button id="cd-yes" class="flex-1 px-4 py-2 bg-red-500 hover:bg-red-600 text-white text-sm font-medium rounded transition-colors">确认删除</button>
<button id="cd-no" class="px-4 py-2 border border-gray-300 dark:border-brand-600 text-brand-600 dark:text-brand-200 text-sm font-medium rounded hover:bg-gray-50 dark:hover:bg-brand-800 transition-colors">取消</button>
</div></div></div>

<script id="app-script">
(function(){
'use strict';
var SK='portfolio_data_v2',SKS='portfolio_settings_v2',XK='PF_EK_2026',DV='v5';
var DD={profile:{name:'张三',role1:'AIGC设计实习生',name2:'张三',tagline:'以 AI 为画笔，以创意为引擎',bio:'专注 AIGC 视觉创意与效果设计，擅长将 AI 生成能力与商业场景深度结合，追求技术与审美的极致融合',school:'某某大学',major:'视觉传达设计',city:'深圳',company:'某互联网公司',background:'视觉传达设计专业出身，在校期间系统学习了平面设计、品牌设计、动态视觉等核心课程，同时自学 AIGC 工具链，将 AI 生成能力融入传统设计流程，形成了「AI 辅助创意 + 人工精修把控」的独特工作方式',direction:'致力于成为 AIGC 视觉创意领域的复合型人才，聚焦 AI 图像生成、效果创意设计、Prompt 工程三大方向，期望在字节跳动效果与创作团队中将 AI 创意能力转化为可量化的商业价值',strengths:'① 设计功底扎实，审美把控力强，能独立完成从概念到交付的全流程；② AIGC 工具链熟练，Midjourney/Stable Diffusion/Runway 等均有深度使用经验；③ Prompt 工程能力突出，能精准控制 AI 输出质量与风格；④ 数据驱动思维，善于通过 A/B 测试优化创意效果；⑤ 高效自驱，快速学习新技术并落地应用',email:'zhangsan@example.com',phone:'138-0000-0000',wechat:'zhangsan_wx',portfolio:'https://zhangsan.design',github:'https://github.com/zhangsan'},works:[{id:'w1',title:'AI 视觉创意海报系列',desc:'基于 Midjourney + Photoshop 后期精修的商业级视觉海报，覆盖品牌广告、社交媒体、活动主视觉等场景',type:'image',media:'',cover:'',group:'g1',tags:['AI图像创作','Prompt工程','视觉设计'],workflow:'需求分析 \u2192 关键词研究 \u2192 Prompt 迭代 \u2192 MJ 生成 \u2192 PS 精修 \u2192 交付',creativeThought:'从品牌调性出发，将产品核心卖点转化为视觉隐喻，通过色彩心理学与构图法则引导视觉焦点',businessAdaptation:'可快速适配字节跳动广告投放场景，A/B 测试不同 Prompt 方向产出多版本素材'},{id:'w2',title:'AI 动态效果创意视频',desc:'使用 Runway Gen-2 + After Effects 制作的短视频创意内容，探索 AI 生成视频在广告效果中的应用',type:'video',media:'',cover:'',group:'g1',tags:['AI视频生成','效果创意','动态设计'],workflow:'创意脚本 \u2192 Runway 生成 \u2192 AE 合成 \u2192 调色输出',creativeThought:'将静态视觉语言延伸至时间维度，通过 AI 生成的不确定性创造意外视觉惊喜',businessAdaptation:'适用于抖音信息流广告、品牌挑战赛等场景，可批量生成差异化视频素材'},{id:'w3',title:'AIGC 工作流效率工具',desc:'自研 Prompt 模板库 + 批量生成脚本，将单次创意产出时间从 2h 压缩至 20min',type:'link',media:'',cover:'',group:'g2',tags:['工作流优化','Prompt工程','效率工具'],workflow:'痛点分析 \u2192 模板设计 \u2192 脚本开发 \u2192 测试迭代 \u2192 团队推广',creativeThought:'从实际项目痛点出发，将重复性工作流程化、模板化，释放创意时间',businessAdaptation:'可直接赋能字节效果团队，提升素材产出效率，降低 A/B 测试成本'}],groups:[{id:'p1',name:'纯Ae作品展示',subgroups:[{id:'g5',name:'完整作品类'},{id:'g6',name:'非完整作品类'}]},{id:'p2',name:'纯AIGC作品展示',subgroups:[{id:'g2',name:'Prompt类'},{id:'g3',name:'图片类'},{id:'g4',name:'视频类'}]},{id:'p3',name:'Ae加AIGC协同作品类',subgroups:[{id:'g1',name:'全部作品'}]}],skills:{design:[{n:'Photoshop',v:88},{n:'After Effects',v:78},{n:'Premiere Pro',v:70},{n:'剪映',v:85}],aigc:[{n:'Midjourney',v:92},{n:'Stable Diffusion',v:85},{n:'Runway Gen-2',v:80},{n:'ChatGPT / Claude',v:88},{n:'Prompt Engineering',v:90},{n:'Seedream',v:82},{n:'Seedance',v:78}]},experiences:[{id:'e1',title:'AIGC 视觉创意实习生',company:'某互联网公司',period:'2025.06 - 至今',desc:'负责 AI 生成视觉内容的创意策划与执行，累计产出 200+ 素材，A/B 测试点击率提升 35%',tags:['AIGC','视觉设计','效果广告']},{id:'e2',title:'品牌视觉设计实习生',company:'某品牌设计公司',period:'2024.09 - 2025.03',desc:'参与品牌全案视觉设计，独立完成 3 个核心项目从概念到交付的全流程',tags:['品牌设计','视觉系统','项目管理']}]};
var S={data:null,editMode:false,filter:'all',currentParent:null,contactOpen:false,dragId:null,confirmCb:null};
function xc(t,k){var r='';for(var i=0;i<t.length;i++)r+=String.fromCharCode(t.charCodeAt(i)^k.charCodeAt(i%k.length));return r}
function enc(t){try{return btoa(unescape(encodeURIComponent(xc(t,XK))))}catch(e){return''}}
function dec(e){try{return xc(decodeURIComponent(escape(atob(e))),XK)}catch(e){return''}}
function gid(){return'w'+Date.now().toString(36)+Math.random().toString(36).substr(2,5)}
function loadD(){try{if(localStorage.getItem('portfolio_ver')!==DV){localStorage.removeItem(SK);localStorage.removeItem(SKS);localStorage.setItem('portfolio_ver',DV)}var s=localStorage.getItem(SK);if(s){S.data=JSON.parse(s);return}}catch(e){}S.data=JSON.parse(JSON.stringify(DD))}
function saveD(){try{localStorage.setItem(SK,JSON.stringify(S.data))}catch(e){}}
function loadSt(){try{var s=localStorage.getItem(SKS);if(s)return JSON.parse(s)}catch(e){}return{token:'',username:'',repo:''}}
function saveSt(s){try{localStorage.setItem(SKS,JSON.stringify({token:enc(s.token),username:enc(s.username),repo:enc(s.repo)}))}catch(e){}}
function getSt(){var s=loadSt();return{token:dec(s.token),username:dec(s.username),repo:dec(s.repo)}}
function esc(t){var d=document.createElement('div');d.textContent=t;return d.innerHTML}
function $(id){return document.getElementById(id)}
function qs(sel){return document.querySelector(sel)}
function qsa(sel){return document.querySelectorAll(sel)}

function renderProfile(){
qsa('[data-e]').forEach(function(el){
var path=el.getAttribute('data-e');
var parts=path.split('.');
var val=S.data;
for(var i=0;i<parts.length;i++){if(val&&val[parts[i]])val=val[parts[i]];else{val='';break}}
if(val!==undefined&&val!==null)el.textContent=val;
if(S.editMode){el.setAttribute('contenteditable','true');el.classList.add('eh')}
else{el.removeAttribute('contenteditable');el.classList.remove('eh')}
});
}

function renderTabs(){
var tb=$('tbar');
var subtb=$('subtbar');
var groups=S.data.groups||[];
var h='<button class="ft px-3 py-1.5 text-xs font-medium rounded-full transition-colors '+(S.filter==='all'&&!S.currentParent?'bg-accent text-white':'bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 hover:bg-gray-200 dark:hover:bg-brand-700')+'" data-f="all" data-type="all">全部</button>';
groups.forEach(function(g){
h+='<button class="ft px-3 py-1.5 text-xs font-medium rounded-full transition-colors '+(S.currentParent===g.id?'bg-accent text-white':'bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 hover:bg-gray-200 dark:hover:bg-brand-700')+'" data-f="'+g.id+'" data-type="parent">'+esc(g.name)+'</button>';
});
tb.innerHTML=h;
qsa('.ft').forEach(function(b){b.addEventListener('click',function(){
var type=this.getAttribute('data-type');
if(type==='all'){
S.currentParent=null;S.filter='all';
}else{
S.currentParent=this.getAttribute('data-f');S.filter=S.currentParent;
}
renderTabs();renderWorks()
})});
var subh='';
if(S.currentParent){
var parentGroup=groups.find(function(g){return g.id===S.currentParent});
if(parentGroup&&parentGroup.subgroups&&parentGroup.subgroups.length){
parentGroup.subgroups.forEach(function(sg){
subh+='<button class="sft px-3 py-1.5 text-xs font-medium rounded-full transition-colors '+(S.filter===sg.id?'bg-accent text-white':'bg-gray-100 dark:bg-brand-800/50 text-brand-500 dark:text-brand-300 hover:bg-gray-200 dark:hover:bg-brand-700')+'" data-sf="'+sg.id+'">'+esc(sg.name)+'</button>';
});
}
}
subtb.innerHTML=subh;
qsa('.sft').forEach(function(b){b.addEventListener('click',function(){
S.filter=this.getAttribute('data-sf');
renderTabs();renderWorks()
})});
}

function renderWorks(){
var g=$('wgrid');
var works=S.data.works||[];
var groups=S.data.groups||[];
var filtered=[];
if(S.filter==='all'){
filtered=works;
}else{
var parentGroup=groups.find(function(pg){return pg.id===S.filter});
if(parentGroup){
var allSubGroupIds=[];
if(parentGroup.subgroups&&parentGroup.subgroups.length){
parentGroup.subgroups.forEach(function(sg){allSubGroupIds.push(sg.id);});
filtered=works.filter(function(w){return allSubGroupIds.indexOf(w.group)!==-1;});
}else{
filtered=works.filter(function(w){return w.group===S.filter});
}
}else{
filtered=works.filter(function(w){return w.group===S.filter});
}
}
if(!filtered.length){g.innerHTML='<div class="col-span-full text-center py-16"><p class="text-sm text-brand-400">暂无作品</p></div>';return}
var h='';
filtered.forEach(function(w){
var mediaHtml='';
if(w.type==='video'&&w.media){
mediaHtml='<div class="relative overflow-hidden aspect-[4/3] bg-brand-100 dark:bg-brand-800"><video class="cc w-full h-full object-cover lm" src="'+esc(w.media)+'" preload="metadata" muted loop playsinline></video><div class="absolute inset-0 flex items-center justify-center bg-black/20 opacity-0 hover:opacity-100 transition-opacity"><svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M8 5v14l11-7z"/></svg></div></div>'
}else if(w.type==='image'&&w.media){
var src=w.cover||w.media;
mediaHtml='<div class="relative overflow-hidden aspect-[4/3] bg-brand-100 dark:bg-brand-800"><img class="cc w-full h-full object-cover lm" src="'+esc(src)+'" alt="'+esc(w.title)+'" loading="lazy"/></div>'
}else if(w.type==='link'&&w.link){
mediaHtml='<a href="'+esc(w.link)+'" target="_blank" rel="noopener" class="relative overflow-hidden aspect-[4/3] bg-brand-100 dark:bg-brand-800 flex items-center justify-center"><svg class="w-10 h-10 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/></svg></a>'
}else{
mediaHtml='<div class="relative overflow-hidden aspect-[4/3] bg-brand-100 dark:bg-brand-800 flex items-center justify-center"><svg class="w-10 h-10 text-brand-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg></div>'
}
var editBtns='';
if(S.editMode){
editBtns='<div class="absolute top-2 right-2 flex gap-1.5 z-10"><button class="ew-edit w-7 h-7 rounded-md bg-white/90 dark:bg-brand-800/90 flex items-center justify-center text-brand-400 hover:text-accent shadow-sm" data-id="'+w.id+'"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg></button><button class="ew-del w-7 h-7 rounded-md bg-white/90 dark:bg-brand-800/90 flex items-center justify-center text-brand-400 hover:text-red-500 shadow-sm" data-id="'+w.id+'"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg></button></div><div class="absolute top-2 left-2 z-10 cursor-grab active:cursor-grabbing" draggable="true" data-drag="'+w.id+'"><svg class="w-5 h-5 text-brand-300 hover:text-accent" fill="currentColor" viewBox="0 0 24 24"><circle cx="9" cy="6" r="1.5"/><circle cx="15" cy="6" r="1.5"/><circle cx="9" cy="12" r="1.5"/><circle cx="15" cy="12" r="1.5"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/></svg></div>'
}
var tagsHtml='';
if(w.tags&&w.tags.length){w.tags.forEach(function(t){tagsHtml+='<span class="px-2 py-0.5 text-[10px] bg-gray-100 dark:bg-brand-800/50 text-brand-400 dark:text-brand-300 rounded-full">'+esc(t)+'</span>'})}
var detailHtml='';
if(w.workflow)detailHtml+='<div class="mt-3 pt-3 border-t border-gray-100 dark:border-brand-800/30"><p class="text-[10px] font-medium text-brand-400 mb-1">工作流</p><p class="text-[11px] text-brand-500 dark:text-brand-300">'+esc(w.workflow)+'</p></div>';
if(w.creativeThought)detailHtml+='<div class="mt-2"><p class="text-[10px] font-medium text-brand-400 mb-1">创作思路</p><p class="text-[11px] text-brand-500 dark:text-brand-300">'+esc(w.creativeThought)+'</p></div>';
if(w.businessAdaptation)detailHtml+='<div class="mt-2"><p class="text-[10px] font-medium text-brand-400 mb-1">业务适配</p><p class="text-[11px] text-brand-500 dark:text-brand-300">'+esc(w.businessAdaptation)+'</p></div>';
h+='<div class="ch relative bg-white dark:bg-brand-900 border border-gray-200 dark:border-brand-800/50 rounded-lg overflow-hidden transition-all duration-300 '+(S.editMode?'do':'')+'" data-wid="'+w.id+'">'+editBtns+mediaHtml+'<div class="p-4"><h3 class="text-sm font-semibold text-gray-900 dark:text-white mb-1">'+esc(w.title)+'</h3><p class="text-xs text-brand-400 leading-relaxed mb-2 line-clamp-2">'+esc(w.desc)+'</p><div class="flex flex-wrap gap-1">'+tagsHtml+'</div>'+detailHtml+'</div></div>'
});
g.innerHTML=h;
qsa('.lm').forEach(function(el){
if(el.tagName==='IMG'){el.onload=function(){this.classList.add('ld')};if(el.complete)el.classList.add('ld')}
else if(el.tagName==='VIDEO'){el.onloadeddata=function(){this.classList.add('ld')};el.load()}
});
bindWorkEvents();
}

function bindWorkEvents(){
qsa('.ew-edit').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();openWorkModal(this.getAttribute('data-id'))})});
qsa('.ew-del').forEach(function(b){b.addEventListener('click',function(e){e.stopPropagation();confirmDelete(this.getAttribute('data-id'))})});
qsa('[data-drag]').forEach(function(el){
el.addEventListener('dragstart',function(e){S.dragId=this.getAttribute('data-drag');e.dataTransfer.effectAllowed='move';this.closest('.ch').style.opacity='0.5'});
el.addEventListener('dragend',function(){this.closest('.ch').style.opacity='1';S.dragId=null});
});
qsa('[data-wid]').forEach(function(card){
card.addEventListener('dragover',function(e){e.preventDefault();e.dataTransfer.dropEffect='move';this.classList.add('ring-2','ring-accent')});
card.addEventListener('dragleave',function(){this.classList.remove('ring-2','ring-accent')});
card.addEventListener('drop',function(e){
e.preventDefault();this.classList.remove('ring-2','ring-accent');
var targetId=this.getAttribute('data-wid');
if(S.dragId&&S.dragId!==targetId){
var works=S.data.works;var fi=-1,ti=-1;
for(var i=0;i<works.length;i++){if(works[i].id===S.dragId)fi=i;if(works[i].id===targetId)ti=i}
if(fi!==-1&&ti!==-1){var item=works.splice(fi,1)[0];works.splice(ti,0,item);saveD();renderWorks()}
}
});
});
}

function renderSkills(){
var cats=[{id:'skd',key:'design'},{id:'ska',key:'aigc'}];
cats.forEach(function(c){
var el=$(c.id);var skills=S.data.skills[c.key]||[];
el.innerHTML='<div class="flex flex-wrap gap-2">'+skills.map(function(s){return '<span class="px-3 py-1.5 text-xs font-medium bg-gray-100 dark:bg-brand-800/50 text-brand-600 dark:text-brand-200 rounded-full">'+esc(s.n)+'</span>'}).join('')+'</div>';
});
}

function renderExperience(){
var el=$('expl');var exps=S.data.experiences||[];
el.innerHTML=exps.map(function(e){
var tags='';
if(e.tags&&e.tags.length){e.tags.forEach(function(t){tags+='<span class="px-2 py-0.5 text-[10px] bg-gray-100 dark:bg-brand-800/50 text-brand-400 dark:text-brand-300 rounded-full">'+esc(t)+'</span>'})}
return '<div class="bg-white dark:bg-brand-900 border border-gray-200 dark:border-brand-800/50 rounded-lg p-6 transition-colors '+(S.editMode?'do':'')+'"><div class="flex flex-col sm:flex-row sm:items-start sm:justify-between mb-3"><div><h3 class="text-sm font-semibold text-gray-900 dark:text-white">'+esc(e.title)+'</h3><p class="text-xs text-accent mt-0.5">'+esc(e.company)+'</p></div><span class="text-xs text-brand-400 mt-1 sm:mt-0">'+esc(e.period)+'</span></div><p class="text-xs text-brand-400 leading-relaxed mb-3">'+esc(e.desc)+'</p><div class="flex flex-wrap gap-1">'+tags+'</div></div>'
}).join('');
}

function renderContact(){
var p=S.data.profile;
var items=[
{icon:'<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>',label:'邮箱',value:p.email,type:'email'},
{icon:'<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>',label:'电话',value:p.phone,type:'tel'},
{icon:'<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M8.691 2.188C3.891 2.188 0 5.476 0 9.53c0 2.212 1.17 4.203 3.002 5.55a.59.59 0 01.213.665l-.39 1.48c-.019.07-.048.141-.048.213 0 .163.13.295.29.295a.326.326 0 00.167-.054l1.903-1.114a.864.864 0 01.717-.098 10.16 10.16 0 002.837.403c.276 0 .543-.027.811-.05-.857-2.578.157-4.972 1.932-6.446 1.703-1.415 3.882-1.98 5.853-1.838-.576-3.583-4.196-6.348-8.596-6.348zM5.785 5.991c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178A1.17 1.17 0 014.623 7.17c0-.651.52-1.18 1.162-1.18zm5.813 0c.642 0 1.162.529 1.162 1.18a1.17 1.17 0 01-1.162 1.178 1.17 1.17 0 01-1.162-1.178c0-.651.52-1.18 1.162-1.18zm5.34 2.867c-1.797-.052-3.746.512-5.28 1.786-1.72 1.428-2.687 3.72-1.78 6.22.942 2.453 3.666 4.229 6.884 4.229.826 0 1.622-.12 2.361-.336a.722.722 0 01.598.082l1.584.926a.272.272 0 00.14.045c.134 0 .24-.11.24-.245 0-.06-.024-.12-.04-.178l-.325-1.233a.492.492 0 01.177-.554C23.028 18.55 24 16.807 24 14.862c0-3.252-2.83-5.94-7.062-6.004zm-2.735 2.97c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.983.97-.983zm4.842 0c.535 0 .969.44.969.982a.976.976 0 01-.969.983.976.976 0 01-.969-.983c0-.542.434-.983.97-.983z"/></svg>',label:'微信',value:p.wechat,type:'text'},
{icon:'<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>',label:'作品集',value:p.portfolio,type:'link'},
{icon:'<svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>',label:'GitHub',value:p.github,type:'link'}
];
var g=$('cgrid');
g.innerHTML=items.filter(function(it){return it.value}).map(function(it){
var val=it.value;
var href=it.type==='email'?'mailto:'+val:it.type==='tel'?'tel:'+val:it.type==='link'?val:'#';
var display=it.type==='link'?'访问链接':val;
return '<a href="'+esc(href)+'" '+(it.type==='link'?'target="_blank" rel="noopener"':'')+' class="flex items-center gap-3 p-4 bg-white dark:bg-brand-900 border border-gray-200 dark:border-brand-800/50 rounded-lg hover:border-accent transition-colors '+(S.editMode?'do':'')+'"><div class="w-9 h-9 rounded-lg bg-gray-50 dark:bg-brand-800 flex items-center justify-center text-brand-400 flex-shrink-0">'+it.icon+'</div><div><p class="text-[10px] text-brand-400">'+esc(it.label)+'</p><p class="text-xs text-brand-700 dark:text-brand-100">'+esc(display)+'</p></div></a>'
}).join('');
var cfc=$('cfc');
cfc.innerHTML=items.filter(function(it){return it.value}).slice(0,3).map(function(it){
var val=it.value;
var display=it.type==='link'?'访问':val;
return '<div class="flex items-center gap-2"><span class="text-brand-400 flex-shrink-0">'+it.icon+'</span><span class="text-[11px] text-brand-600 dark:text-brand-200 truncate">'+esc(display)+'</span></div>'
}).join('');
}

function openWorkModal(id){
var modal=$('wm');var form=$('wform');
var allGroups=[];
S.data.groups.forEach(function(pg){
if(pg.subgroups&&pg.subgroups.length){
pg.subgroups.forEach(function(sg){
allGroups.push(sg);
});
}else{
allGroups.push(pg);
}
});
$('wf-group').innerHTML=allGroups.map(function(g){return'<option value="'+g.id+'">'+esc(g.name)+'</option>'}).join('');
if(id){
var w=S.data.works.find(function(x){return x.id===id});
if(!w)return;
$('wmt').textContent='编辑作品';
$('wf-id').value=w.id;
$('wf-title').value=w.title;
$('wf-desc').value=w.desc;
$('wf-type').value=w.type;
$('wf-group').value=w.group;
$('wf-media').value=w.media||'';
$('wf-cover').value=w.cover||'';
$('wf-link').value=w.link||'';
$('wf-tags').value=(w.tags||[]).join(',');
$('wf-wf').value=w.workflow||'';
$('wf-ct').value=w.creativeThought||'';
$('wf-ba').value=w.businessAdaptation||'';
}else{
$('wmt').textContent='添加作品';
form.reset();
$('wf-id').value='';
}
modal.classList.remove('hidden');
}

function closeWorkModal(){$('wm').classList.add('hidden');$('wform').reset();$('ups').classList.add('hidden')}

function confirmDelete(id){
var w=S.data.works.find(function(x){return x.id===id});
if(!w)return;
$('cd-msg').textContent='确定要删除作品「'+w.title+'」吗？此操作不可撤销。';
$('cdlg').classList.remove('hidden');
S.confirmCb=function(){
S.data.works=S.data.works.filter(function(x){return x.id!==id});
saveD();renderWorks();$('cdlg').classList.add('hidden');S.confirmCb=null
};
}

async function uploadToGitHub(file,onProgress){
var st=getSt();
if(!st.token||!st.username||!st.repo){return null}
var path='media/'+Date.now()+'_'+file.name;
var url='https://api.github.com/repos/'+st.username+'/'+st.repo+'/contents/'+path;
var reader=new FileReader();
return new Promise(function(resolve,reject){
reader.onload=async function(){
try{
var content=btoa(reader.result);
var res=await fetch(url,{method:'PUT',headers:{'Authorization':'token '+st.token,'Content-Type':'application/json'},body:JSON.stringify({message:'Upload '+file.name,content:content})});
if(!res.ok){var err=await res.json();throw new Error(err.message||'Upload failed')}
var data=await res.json();
resolve(data.content.download_url);
}catch(e){reject(e)}
};
reader.onerror=reject;
reader.readAsDataURL(file);
});
}

function toggleEditMode(){
S.editMode=!S.editMode;
$('eb').classList.toggle('hidden',!S.editMode);
$('awb').classList.toggle('hidden',!S.editMode);
$('awb').style.display=S.editMode?'inline-flex':'none';
$('sb').classList.toggle('hidden',!S.editMode);
$('sb').style.display=S.editMode?'inline-flex':'none';
renderProfile();renderWorks();renderExperience();renderContact();
}

function initEvents(){
$('tt').addEventListener('click',function(){document.documentElement.classList.toggle('dark')});
$('mb').addEventListener('click',function(){$('mm').classList.toggle('hidden')});
qsa('.mn').forEach(function(a){a.addEventListener('click',function(){$('mm').classList.add('hidden')})});
$('sb').addEventListener('click',function(){
var st=getSt();
$('sf-token').value=st.token;
$('sf-user').value=st.username;
$('sf-repo').value=st.repo;
$('stm').classList.remove('hidden');
});
$('stmc').addEventListener('click',function(){$('stm').classList.add('hidden')});
$('stm-overlay').addEventListener('click',function(){$('stm').classList.add('hidden')});
$('sf-cancel').addEventListener('click',function(){$('stm').classList.add('hidden')});
$('sform').addEventListener('submit',function(e){
e.preventDefault();
saveSt({token:$('sf-token').value,username:$('sf-user').value,repo:$('sf-repo').value});
$('stm').classList.add('hidden');
});
$('awb').addEventListener('click',function(){openWorkModal(null)});
$('wmc').addEventListener('click',closeWorkModal);
$('wm-overlay').addEventListener('click',closeWorkModal);
$('wf-cancel').addEventListener('click',closeWorkModal);
$('wform').addEventListener('submit',async function(e){
e.preventDefault();
var id=$('wf-id').value;
var fileInput=$('wf-file');
var mediaUrl=$('wf-media').value;
var coverUrl=$('wf-cover').value;
if(fileInput.files.length>0){
var ups=$('ups');ups.classList.remove('hidden');ups.textContent='上传中...';
try{var url=await uploadToGitHub(fileInput.files[0]);if(url){mediaUrl=url;coverUrl=url;ups.textContent='上传成功！'}else{ups.textContent='未配置 GitHub，仅保存 URL'}}catch(err){ups.textContent='上传失败：'+err.message}
}
var wData={title:$('wf-title').value,desc:$('wf-desc').value,type:$('wf-type').value,group:$('wf-group').value,media:mediaUrl,cover:coverUrl,link:$('wf-link').value,tags:$('wf-tags').value?$('wf-tags').value.split(',').map(function(t){return t.trim()}).filter(Boolean):[],workflow:$('wf-wf').value,creativeThought:$('wf-ct').value,businessAdaptation:$('wf-ba').value};
if(id){
var idx=S.data.works.findIndex(function(x){return x.id===id});
if(idx!==-1){Object.assign(S.data.works[idx],wData)}
}else{
wData.id=gid();S.data.works.push(wData);
}
saveD();renderWorks();closeWorkModal();
});
$('cd-yes').addEventListener('click',function(){if(S.confirmCb)S.confirmCb()});
$('cd-no').addEventListener('click',function(){$('cdlg').classList.add('hidden');S.confirmCb=null});
$('cd-overlay').addEventListener('click',function(){$('cdlg').classList.add('hidden');S.confirmCb=null});
$('cft').addEventListener('click',function(){
S.contactOpen=!S.contactOpen;
var p=$('cfp');
if(S.contactOpen){p.classList.remove('scale-95','opacity-0','pointer-events-none');p.classList.add('scale-100','opacity-100')}
else{p.classList.add('scale-95','opacity-0','pointer-events-none');p.classList.remove('scale-100','opacity-100')}
$('cio').classList.toggle('hidden',S.contactOpen);
$('cic').classList.toggle('hidden',!S.contactOpen);
});
document.addEventListener('keydown',function(e){
if(e.ctrlKey&&e.shiftKey&&e.key==='E'){e.preventDefault();toggleEditMode()}
if(e.key==='Escape'){
if(!$('wm').classList.contains('hidden'))closeWorkModal();
if(!$('stm').classList.contains('hidden'))$('stm').classList.add('hidden');
if(!$('cdlg').classList.contains('hidden')){$('cdlg').classList.add('hidden');S.confirmCb=null}
}
});
qsa('[contenteditable]').forEach(function(el){
el.addEventListener('blur',function(){
var path=this.getAttribute('data-e');
if(!path)return;
var parts=path.split('.');
var obj=S.data;
for(var i=0;i<parts.length-1;i++){if(obj[parts[i]])obj=obj[parts[i]]}
var last=parts[parts.length-1];
if(obj)obj[last]=this.textContent;
saveD();
});
});
var observer=new IntersectionObserver(function(entries){
entries.forEach(function(entry){if(entry.isIntersecting)entry.target.classList.add('vis')});
},{threshold:0.1});
qsa('.fi').forEach(function(el){observer.observe(el)});
var navLinks=qsa('.nl');
var sections=qsa('section[id]');
window.addEventListener('scroll',function(){
var sy=window.scrollY+100;
sections.forEach(function(sec){
if(sy>=sec.offsetTop&&sy<sec.offsetTop+sec.offsetHeight){
navLinks.forEach(function(l){l.classList.toggle('act',l.getAttribute('href')==='#'+sec.id)});
}
});
var nb=$('nb');
if(window.scrollY>50){nb.classList.add('shadow-sm')}else{nb.classList.remove('shadow-sm')}
});
}

function init(){
loadD();renderProfile();renderTabs();renderWorks();renderSkills();renderExperience();renderContact();initEvents();
}
if(document.readyState==='loading')document.addEventListener('DOMContentLoaded',init);else init();
})();
</script>
</body>
</html>
